  "homepage": "https://github.com/git2hdd/git2hdd#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/git2hdd/git2hdd.git"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "express": "^5.2.1",
    "ora": "^8.1.1",
    "semver": "^7.6.3"
  },
  "devDependencies": {
    "fast-check": "^3.22.0",
    "vitest": "^2.1.8"
