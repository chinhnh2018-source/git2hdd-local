{
  "name": "git2hdd",
  "version": "1.0.0",
  "description": "Automate Git backup from SSD to multiple HDDs on Windows",
  "type": "module",
  "bin": {
    "git2hdd": "./bin/git2hdd.js"
  },
  "main": "./src/index.js",
  "files": [
